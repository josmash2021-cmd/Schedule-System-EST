{
  "version": 2,
  "buildCommand": "echo 'Static site ready v3'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/productos", "destination": "/products", "permanent": true },
    { "source": "/solicitud-servicio", "destination": "/book-appointment", "permanent": true },
    { "source": "/carrito", "destination": "/cart", "permanent": true },
    { "source": "/terminos", "destination": "/terms", "permanent": true },
    { "source": "/politicas", "destination": "/privacy", "permanent": true }
  ],
  "rewrites": [
    { "source": "/products", "destination": "/productos.html" },
    { "source": "/book-appointment", "destination": "/solicitud-servicio.html" },
    { "source": "/cart", "destination": "/carrito.html" },
    { "source": "/terms", "destination": "/terminos.html" },
    { "source": "/privacy", "destination": "/politicas.html" },
    { "source": "/api/:path*", "destination": "https://schedule-system-est-production.up.railway.app/api/:path*" }
  ]
}
