{
  "version": 2,
  "buildCommand": "echo 'Static site ready v3'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/productos", "destination": "/products", "permanent": true },
    { "source": "/solicitud-servicio", "destination": "/book-appointment", "permanent": true },
    { "source": "/carrito", "destination": "/cart", "permanent": true },
    { "source": "/terminos", "destination": "/terms", "permanent": true },
    { "source": "/politicas", "destination": "/privacy", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://www.electronicservicetechnology.com/api/:path*" },
    { "source": "/x/:path*", "destination": "https://www.electronicservicetechnology.com/x/:path*" },
    { "source": "/bot-qr", "destination": "https://www.electronicservicetechnology.com/bot-qr" },
    { "source": "/bot-qr.png", "destination": "https://www.electronicservicetechnology.com/bot-qr.png" },
    { "source": "/voz/:path*", "destination": "https://www.electronicservicetechnology.com/voz/:path*" }
  ]
}
