# ===== Configuración del bot de WhatsApp =====
# Copia este archivo a ".env" y rellena los valores.

# Clave de API del proveedor de LLM (OpenAI, Gemini, Groq, etc.)
# Si se deja vacía, el bot arranca igual pero responde con un mensaje
# de fallback avisando que un asesor humano atenderá pronto.
OPENAI_API_KEY=

# URL base de la API (compatible con OpenAI). Ejemplos:
#   OpenAI:  https://api.openai.com/v1
#   Gemini:  https://generativelanguage.googleapis.com/v1beta/openai/
#   Groq:    https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Modelo a usar (ej: gpt-4o-mini, gemini-1.5-flash, llama-3.1-8b-instant)
OPENAI_MODEL=gpt-4o-mini

# Número del dueño del negocio con código de país, sin "+" ni espacios.
# Ejemplo México: 521XXXXXXXXXX
# A este número llegan los avisos de citas nuevas y solicitudes de humano.
OWNER_NUMBER=

# Nombre del negocio (también se puede ajustar en config/negocio.json)
BUSINESS_NAME=TechFix Solutions

# URL base del sitio web del negocio (sistema de citas en línea).
# Las citas que agenda el bot se registran ahí (mismo sistema que el
# formulario web: panel admin y notificaciones incluidas).
WEBSITE_API_URL=https://electronicservicetechnology.com

# ----- Notas de voz (transcripción Whisper) -----
# Clave de API para transcribir audios a texto. Recomendado: Groq (gratis).
# Créala en https://console.groq.com/keys (2 minutos, sin tarjeta).
TRANSCRIBE_API_KEY=

# Proveedor de transcripción (compatible con OpenAI). Por defecto Groq:
TRANSCRIBE_BASE_URL=https://api.groq.com/openai/v1
TRANSCRIBE_MODEL=whisper-large-v3

# Números que reciben los avisos del bot, separados por coma.
# Si se deja vacío, se usa OWNER_NUMBER.
NOTIFY_NUMBERS=
