DATABASE_URL=postgresql://user:password@localhost:5432/est_appointments
ADMIN_PASSWORD=tu_contraseña_segura
CORS_ORIGIN=*
PORT=3000
CALLMEBOT_API_KEY=1367816
OWNER_PHONE=12055737840

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SMS_FROM=+15551234567

# ===== Bot de WhatsApp (wa-bot) — server/wa-bot/ =====
# Activar/desactivar el bot en este mismo proceso (por defecto activado)
BOT_ENABLED=true

# IA (Kimi Code, compatible con OpenAI)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.kimi.com/coding/v1
OPENAI_MODEL=k3

# Avisos del bot (citas nuevas, solicitudes de supervisor), separados por coma
OWNER_NUMBER=12055737840
NOTIFY_NUMBERS=12055737840,13854612042
BUSINESS_NAME=ElectronicST
WEBSITE_API_URL=https://electronicservicetechnology.com

# Transcripción de notas de voz (Whisper vía Groq)
TRANSCRIBE_API_KEY=
TRANSCRIBE_BASE_URL=https://api.groq.com/openai/v1
TRANSCRIBE_MODEL=whisper-large-v3

# Nota de voz de bienvenida (ElevenLabs, texto a voz).
# Requiere plan de pago para usar voces de biblioteca por API.
# Si se deja vacía, la bienvenida se manda como texto normal.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=9Godp7dNohUvXk6qp0gS

# URL pública de ESTE servidor (sin / final). Instagram la necesita para
# adjuntar la nota de voz de bienvenida (los audios se sirven en /voz/).
PUBLIC_BASE_URL=https://schedule-system-est-production.up.railway.app

# Persistencia del bot de WhatsApp: apuntar al volumen de Railway
# (ver wa-bot/RAILWAY.md)
AUTH_DIR=/data/auth_info
DATA_DIR=/data/data

# ===== Bot de Instagram (ig-bot) — server/ig-bot/ =====
# Instagram Direct (API oficial de Meta) — ver ig-bot/RAILWAY.md
# Token de acceso de la cuenta de Instagram (Meta for Developers).
# Si se deja vacío, el webhook funciona pero los envíos solo se loguean.
IG_ACCESS_TOKEN=
# ID de la cuenta de Instagram Business (ig_user_id)
IG_USER_ID=
# Cadena inventada por ti; la misma que pongas al configurar el webhook en Meta
IG_VERIFY_TOKEN=
# App secret de la app de Meta (verificación de firma de los webhooks)
IG_APP_SECRET=
GRAPH_API_VERSION=v21.0

# Avisos del bot de Instagram al dueño por WhatsApp vía CallMeBot (HTTP).
# IG_NOTIFY_PHONE: default OWNER_PHONE (o 12055737840).
# IG_CALLMEBOT_API_KEY: default CALLMEBOT_API_KEY (la de arriba).
IG_NOTIFY_PHONE=
IG_CALLMEBOT_API_KEY=

# Persistencia del bot de Instagram (default: server/ig-bot/data).
# Si se define, tiene prioridad sobre DATA_DIR.
DATA_DIR_IG=
